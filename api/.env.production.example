# =============================================================================
# LiteEvent API - Production Environment Variables
# =============================================================================
# IMPORTANT: Copy this to .env.production and fill in your actual values
# NEVER commit .env.production to git!
# =============================================================================

# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Use managed PostgreSQL service (AWS RDS, Supabase, DigitalOcean, etc.)
DATABASE_URL=postgres://username:password@your-db-host.cloud.com:5432/liteevent

# ── Redis (Session & Caching) ────────────────────────────────────────────────
# Use managed Redis service (AWS ElastiCache, Upstash, Redis Cloud, etc.)
REDIS_URL=redis://your-redis-host.cloud.com:6379

# Or Redis with password:
# REDIS_URL=redis://:password@your-redis-host.cloud.com:6379

# ── JWT Secrets ──────────────────────────────────────────────────────────────
# CRITICAL: Generate strong random secrets (64+ characters)
# Never use the same secrets as development!
# Generate with: openssl rand -base64 64
JWT_SECRET=YOUR_PRODUCTION_JWT_SECRET_HERE_MINIMUM_64_CHARACTERS
JWT_REFRESH_SECRET=YOUR_PRODUCTION_REFRESH_SECRET_HERE_DIFFERENT_FROM_JWT_SECRET

# ── CORS & Frontend URLs ─────────────────────────────────────────────────────
# Your production domains (comma-separated, no spaces)
CORS_ORIGIN=https://liteevent.com,https://www.liteevent.com,https://vendors.liteevent.com

# Main web app URL
FRONTEND_URL=https://liteevent.com

# Vendor portal URL
VENDOR_APP_URL=https://vendors.liteevent.com

# ── Email Service (Resend) ───────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_PRODUCTION_KEY_HERE

# Verified sender email (must be verified in Resend dashboard)
MAIL_FROM_EMAIL=notifications@liteevent.com
MAIL_FROM_NAME=LiteEvent

# ── Google OAuth ─────────────────────────────────────────────────────────────
# From: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://api.liteevent.com/auth/google/callback

# ── Google Maps API ──────────────────────────────────────────────────────────
# For venue search and autocomplete
VENDOR_GOOGLE_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── Stripe (Payments) ────────────────────────────────────────────────────────
# CRITICAL: Use LIVE keys, not test keys!
# From: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY

# Stripe Price IDs (from Stripe Dashboard → Products)
STRIPE_STARTER_PRICE_ID=price_live_YOUR_STARTER_PRICE_ID
STRIPE_PRO_PRICE_ID=price_live_YOUR_PRO_PRICE_ID

# Stripe Webhook Secret (from Stripe Dashboard → Webhooks)
# Webhook URL: https://api.liteevent.com/api/subscription/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET

# ── Anthropic AI (Claude) ────────────────────────────────────────────────────
# From: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_API_KEY

# ── Cloudinary (Image Upload) ────────────────────────────────────────────────
# From: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── AWS (S3, SES, etc.) ──────────────────────────────────────────────────────
# Optional: If using AWS services
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1

# ── SMS Notifications (Optional) ─────────────────────────────────────────────
# Brevo SMS sender name (max 11 alphanumeric chars)
BREVO_SMS_SENDER=LiteEvent

# WhatsApp template IDs (if using WhatsApp notifications)
BREVO_WHATSAPP_TEMPLATE_INVITE=0
BREVO_WHATSAPP_TEMPLATE_RSVP=0

# ── Monitoring & Logging (Optional) ──────────────────────────────────────────
# Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────────────────────────
# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100

# Session expiry (in milliseconds, 7 days = 604800000)
SESSION_EXPIRY=604800000

# ── Feature Flags (Optional) ─────────────────────────────────────────────────
# ENABLE_ANALYTICS=true
# ENABLE_AI_FEATURES=true
# MAINTENANCE_MODE=false

# =============================================================================
# DEPLOYMENT CHECKLIST:
# =============================================================================
# [ ] Generated strong random JWT secrets
# [ ] Updated all URLs to production domains
# [ ] Using production Stripe keys (sk_live_...)
# [ ] Configured Stripe webhook
# [ ] Updated Google OAuth redirect URI
# [ ] Verified sender email in Resend
# [ ] Tested database connection
# [ ] Tested Redis connection
# [ ] Set up SSL certificates
# [ ] Configured DNS records
# [ ] Set up monitoring (Sentry, DataDog, etc.)
# [ ] Configured backups
# =============================================================================
