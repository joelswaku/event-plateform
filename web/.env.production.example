# =============================================================================
# LiteEvent Web - Production Environment Variables
# =============================================================================
# IMPORTANT: Copy this to .env.production and fill in your actual values
# NEVER commit .env.production to git!
# =============================================================================

# ── API Configuration ────────────────────────────────────────────────────────
# Public API URL - Set in GitHub Secrets as PRODUCTION_API_URL
# In production, this is passed as a Docker build arg, not from this file!
#
# For AWS ECS deployment:
NEXT_PUBLIC_API_URL=http://liteevent-production-alb-976548681.us-east-1.elb.amazonaws.com/api
#
# Or use subdomain (after adding DNS):
# NEXT_PUBLIC_API_URL=https://api.liteevent.com/api

# ── Application URLs ─────────────────────────────────────────────────────────
# Your production web app URL
NEXT_PUBLIC_APP_URL=https://liteevent.com

# ── Google OAuth ─────────────────────────────────────────────────────────────
# From: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://api.liteevent.com/auth/google/callback

# ── Google Maps API ──────────────────────────────────────────────────────────
# For venue search
VENDOR_GOOGLE_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── Stripe (Payments) ────────────────────────────────────────────────────────
# CRITICAL: Use LIVE publishable key, not test key!
# From: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_PUBLISHABLE_KEY

# Stripe Price IDs (LIVE prices from Stripe Dashboard → Products)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_live_YOUR_STARTER_PRICE_ID
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_live_YOUR_PRO_PRICE_ID

# Legacy (backward compatibility)
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_live_YOUR_PREMIUM_PRICE_ID

# ── Analytics (Optional) ─────────────────────────────────────────────────────
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook Pixel
# NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXX

# ── Error Tracking (Optional) ────────────────────────────────────────────────
# Sentry DSN
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Feature Flags (Optional) ─────────────────────────────────────────────────
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_AI_CHATBOT=true
# NEXT_PUBLIC_MAINTENANCE_MODE=false

# =============================================================================
# DEPLOYMENT CHECKLIST:
# =============================================================================
# [ ] Updated INTERNAL_API_URL to production API
# [ ] Using production Stripe publishable key (pk_live_...)
# [ ] Updated price IDs to production prices
# [ ] Configured Google OAuth
# [ ] Set NEXT_PUBLIC_APP_URL to production domain
# [ ] Enabled analytics (if applicable)
# [ ] Configured error tracking (if applicable)
# [ ] Tested payment flow with live Stripe
# =============================================================================
