# Production Environment Configuration
# Copy this file to terraform.tfvars and fill in the actual values
# IMPORTANT: Use strong, unique secrets for production!

# AWS Configuration
aws_region   = "us-east-1"
project_name = "event-platform"
environment  = "production"

# Network
vpc_cidr = "10.0.0.0/16"

# Database (RDS PostgreSQL) - Production configuration
db_instance_class = "db.t4g.small" # Can scale to db.t4g.medium or larger
db_name           = "eventplatform"
db_username       = "postgres"     # Set in terraform.tfvars
db_password       = "CHANGE_ME"    # Set in terraform.tfvars (generate strong password)

# Redis (Enabled for production)
enable_redis    = true
redis_node_type = "cache.t4g.small"

# SSL Certificates (Create these in ACM first)
# NOTE: CloudFront certificate MUST be in us-east-1 region
acm_certificate_arn            = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID"
acm_certificate_arn_cloudfront = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID"

# Domain Names
domain_name         = "yourdomain.com"
web_domain_name     = "app.yourdomain.com"
vendors_domain_name = "vendors.yourdomain.com"

# GitHub OIDC (for CI/CD without AWS keys)
github_org  = "your-github-org"
github_repo = "event-platform"

# ========================================
# Application Secrets
# ========================================
# IMPORTANT: Generate strong random values for ALL secrets!
# After first apply, consider rotating these through AWS Secrets Manager

# JWT Secrets (generate with: openssl rand -base64 32)
jwt_secret         = "CHANGE_ME" # Generate unique value
jwt_refresh_secret = "CHANGE_ME" # Generate unique value

# Stripe (use LIVE keys for production)
stripe_secret_key      = "sk_live_XXXXX"
stripe_publishable_key = "pk_live_XXXXX"
stripe_webhook_secret  = "whsec_XXXXX"

# Google OAuth (Production credentials)
google_client_id     = "XXXXX.apps.googleusercontent.com"
google_client_secret = "CHANGE_ME"

# Resend (Email)
resend_api_key = "re_XXXXX"

# Cloudinary (Optional - for image hosting)
cloudinary_cloud_name = ""
cloudinary_api_key    = ""
cloudinary_api_secret = ""
