# =============================================================================
# LiteEvent Mobile - Production Environment Variables
# =============================================================================
# IMPORTANT: Copy this to .env.production and fill in your actual values
# NEVER commit .env.production to git!
# =============================================================================

# ── API Configuration ────────────────────────────────────────────────────────
# Production API endpoint
EXPO_PUBLIC_API_URL=https://api.liteevent.com/api

# ── Web App URL ──────────────────────────────────────────────────────────────
# For deep linking to event pages
EXPO_PUBLIC_WEB_URL=https://liteevent.com

# ── Google OAuth ─────────────────────────────────────────────────────────────
# From: https://console.cloud.google.com/apis/credentials

# Web client ID (for Google Sign-In)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# iOS client ID (create in Google Console → iOS application)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_GOOGLE_IOS_CLIENT_ID.apps.googleusercontent.com

# Android client ID (create in Google Console → Android application)
# Package name: com.liteevent.app (or your actual package name)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_GOOGLE_ANDROID_CLIENT_ID.apps.googleusercontent.com

# ── Google Maps API ──────────────────────────────────────────────────────────
# For venue search and maps
VENDOR_GOOGLE_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── Stripe (Payments) ────────────────────────────────────────────────────────
# CRITICAL: Use LIVE keys, not test keys!
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_PUBLISHABLE_KEY

# Stripe Price IDs (LIVE prices)
EXPO_PUBLIC_STRIPE_STARTER_PRICE_ID=price_live_YOUR_STARTER_PRICE_ID
EXPO_PUBLIC_STRIPE_PRO_PRICE_ID=price_live_YOUR_PRO_PRICE_ID

# ── App Configuration ────────────────────────────────────────────────────────
# App scheme for deep linking
EXPO_PUBLIC_APP_SCHEME=liteevent

# ── Analytics (Optional) ─────────────────────────────────────────────────────
# Google Analytics (Firebase)
# EXPO_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Amplitude
# EXPO_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_key

# ── Error Tracking (Optional) ────────────────────────────────────────────────
# Sentry DSN
# EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Push Notifications (Optional) ────────────────────────────────────────────
# Expo Push Token
# EXPO_PUBLIC_PUSH_TOKEN=your_expo_push_token

# OneSignal App ID
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id

# ── Feature Flags (Optional) ─────────────────────────────────────────────────
# EXPO_PUBLIC_ENABLE_ANALYTICS=true
# EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
# EXPO_PUBLIC_ENABLE_AI_FEATURES=true

# =============================================================================
# DEPLOYMENT CHECKLIST:
# =============================================================================
# [ ] Updated API_URL to production API
# [ ] Updated WEB_URL to production web app
# [ ] Using production Stripe key (pk_live_...)
# [ ] Updated price IDs to production prices
# [ ] Created all 3 Google OAuth clients (Web, iOS, Android)
# [ ] Configured Google Sign-In in app.json
# [ ] Set up deep linking (apple-app-site-association)
# [ ] Configured push notifications (if applicable)
# [ ] Set up analytics (if applicable)
# [ ] Tested in production mode: expo build
# [ ] Submitted to App Store
# [ ] Submitted to Google Play
# =============================================================================

# =============================================================================
# EXPO BUILD PROFILES:
# =============================================================================
# Development: npx expo start
# Preview: eas build --profile preview
# Production: eas build --profile production --platform all
# Submit: eas submit --platform all
# =============================================================================
